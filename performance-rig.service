[Unit]
Description=Live Performance Rig Controller
After=network.target sound.target pipewire.service

[Service]
Type=simple
User=nmlstyl
Group=nmlstyl
WorkingDirectory=/home/nmlstyl/rig
Environment="DISPLAY=:0"
Environment="XAUTHORITY=/home/nmlstyl/.Xauthority"
ExecStart=/usr/bin/python3 /home/nmlstyl/rig/controller.py
Restart=on-failure
RestartSec=5

# Audio settings
Environment="PIPEWIRE_LATENCY=512/48000"

[Install]
WantedBy=multi-user.target
